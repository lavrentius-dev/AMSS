<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AMSS" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/dark_khaki</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Status bar color. Will be overwritten dynamically in MainActivity -->
        <item name="android:statusBarColor">@color/dark_khaki</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Force default text colors to antique_white -->
        <item name="android:textColor">@color/antique_white</item>
        <item name="android:textColorPrimary">@color/antique_white</item>
        <item name="android:textColorSecondary">@color/antique_white</item>

        <!-- Material "On" colors: Ensures text/icons on components stay antique_white
             even if the system is in Light mode -->
        <item name="colorOnPrimary">@color/antique_white</item>
        <item name="colorOnSecondary">@color/antique_white</item>
        <item name="colorOnSurface">@color/antique_white</item>
        <item name="colorOnBackground">@color/antique_white</item>
        <item name="colorOnError">@color/white</item>

        <!-- Global style for RadioButtons -->
        <item name="radioButtonStyle">@style/Widget.AMSS.RadioButton</item>

        <!-- Customize AlertDialog to match the dark earthy theme -->
        <item name="alertDialogTheme">@style/Theme.AMSS.AlertDialog</item>
        <item name="materialAlertDialogTheme">@style/Theme.AMSS.AlertDialog</item>
    </style>

    <!-- Specific style for RadioButtons to ensure text color and button tint are respected -->
    <style name="Widget.AMSS.RadioButton" parent="Widget.MaterialComponents.CompoundButton.RadioButton">
        <item name="android:textColor">@color/antique_white</item>
        <item name="buttonTint">@color/antique_white</item>
    </style>

    <!-- Dialog style that forces a dark background and antique_white text across all modes -->
    <style name="Theme.AMSS.AlertDialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorSurface">@color/very_dark_grey</item>
        <item name="colorOnSurface">@color/antique_white</item>

        <!-- Explicitly set backgrounds to override system Light theme defaults -->
        <item name="android:windowBackground">@color/very_dark_grey</item>
        <item name="android:background">@color/very_dark_grey</item>

        <!-- Force title and message colors to antique_white -->
        <item name="android:textColor">@color/antique_white</item>
        <item name="android:textColorPrimary">@color/antique_white</item>
        <item name="android:textColorSecondary">@color/antique_white</item>

        <!-- Use specific title styling for AppCompat and Material dialogs -->
        <item name="titleTextAppearance">@style/Theme.AMSS.AlertDialog.Title</item>
        <item name="materialAlertDialogTitleTextStyle">@style/Theme.AMSS.AlertDialog.Title</item>

        <item name="buttonBarPositiveButtonStyle">@style/Widget.AMSS.Button.TextButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.AMSS.Button.TextButton</item>
    </style>

    <!-- Force the dialog title to use antique_white -->
    <style name="Theme.AMSS.AlertDialog.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/antique_white</item>
        <item name="android:textColorPrimary">@color/antique_white</item>
    </style>

    <style name="Widget.AMSS.Button.TextButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/antique_white</item>
        <item name="rippleColor">@color/dark_khaki</item>
    </style>

    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14sp</item>
        <item name="textAllCaps">true</item>
    </style>
</resources>
